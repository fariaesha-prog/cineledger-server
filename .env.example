# ==========================================
# CineLedger Server - Environment Variables
# Copy this file to .env and fill in real values.
# Never commit the real .env file.
# ==========================================

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.22xo6tq.mongodb.net/?appName=Cluster0


# JWT (used later, when auth is implemented)
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt
BCRYPT_SALT_ROUNDS=12

# TMDB API
TMDB_API_KEY=your_tmdb_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
